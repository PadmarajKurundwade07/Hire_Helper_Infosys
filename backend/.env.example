# ============================================
# HireHelper Backend - Environment Variables
# ============================================

# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Option 1: Use DATABASE_URL (recommended for production on Render)
# Render PostgreSQL automatically provides this
# DATABASE_URL=postgresql://user:password@host:port/database

# Option 2: Use individual database credentials
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hire_helper

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=1d

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Use Gmail App Password (not your regular password)
# How to create App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Create App Password for "Mail" and "Windows Computer"
# 4. Use the generated password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ============================================
# PRODUCTION DEPLOYMENT INSTRUCTIONS
# ============================================
#
# For Render deployment:
# 1. Set DATABASE_URL from Render PostgreSQL service
# 2. Set SMTP credentials for email notifications
# 3. JWT_SECRET will be auto-generated by Render
# 4. All other values can use defaults
#
# For local development:
# 1. Use DATABASE_URL or individual DB credentials
# 2. Ensure PostgreSQL is running locally
# 3. Create database: createdb hire_helper
# 4. Run: npm run dev

